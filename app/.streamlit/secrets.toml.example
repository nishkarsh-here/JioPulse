# Copy this file to .streamlit/secrets.toml and fill in your values.
# Do NOT commit the real secrets.toml (it is in .gitignore).

# Supabase (existing backend)
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_KEY = "your-supabase-anon-or-service-key"

# Gemini (powers the JioPulse AI assistant: RAG + agent). Free key from
# https://aistudio.google.com/apikey
GEMINI_API_KEY = "AIza..."

# Gmail account used to send teacher password-reset emails. GMAIL_APP_PASSWORD
# must be an App Password (Google Account > Security > App Passwords),
# not your regular login password - requires 2-Step Verification enabled.
GMAIL_ADDRESS = "you@gmail.com"
GMAIL_APP_PASSWORD = "xxxx xxxx xxxx xxxx"
